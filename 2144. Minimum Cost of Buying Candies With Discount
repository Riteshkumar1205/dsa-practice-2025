#include <vector>
#include <algorithm>

class Solution {
public:
    int minimumCost(std::vector<int>& cost) {
        // Sort costs in descending order
        std::sort(cost.begin(), cost.end(), std::greater<int>());
        
        int totalCost = 0;
        
        for (int i = 0; i < cost.size(); ++i) {
            // Every 3rd candy (index 2, 5, 8, ...) is free, skip it
            if ((i + 1) % 3 == 0) {
                continue;
            }
            totalCost += cost[i];
        }
        
        return totalCost;
    }
};
