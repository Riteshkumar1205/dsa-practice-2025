class Solution {
public:
    int minFlips(string s) {
        int n = s.size();
        string ss = s + s;

        string alt1 = "", alt2 = "";

        for(int i = 0; i < ss.size(); i++){
            alt1 += (i % 2 == 0 ? '0' : '1');
            alt2 += (i % 2 == 0 ? '1' : '0');
        }

        int res = INT_MAX;
        int diff1 = 0, diff2 = 0;
        int l = 0;

        for(int r = 0; r < ss.size(); r++) {

            if(ss[r] != alt1[r]) diff1++;
            if(ss[r] != alt2[r]) diff2++;

            if(r - l + 1 > n) {
                if(ss[l] != alt1[l]) diff1--;
                if(ss[l] != alt2[l]) diff2--;
                l++;
            }

            if(r - l + 1 == n) {
                res = min(res, min(diff1, diff2));
            }
        }

        return res;
    }
};
